# kaggle CV datasets (large; download via npm run cv:download-samples)
/data/cv

# OWL-ViT ONNX model — 156MB, too large for Vercel deploy and not needed in the
# repo (prod loads from Vercel Blob via NEXT_PUBLIC_OWLVIT_MODEL_BASE; dev loads
# from Hugging Face). Optional local copy for offline dev lives here.
/data/models

# FlagDown YOLO training workspace: venv + ultralytics runs (large, regenerable).
# Training scripts live in /ml; the exported ONNX is committed to public/models.
/data/ml

# Ultralytics pretrained checkpoint + stray run dirs (downloaded during train)
yolov8n.pt
/runs

# vercel
.vercel

# typescript
*.tsbuildinfo

# idea files
.idea